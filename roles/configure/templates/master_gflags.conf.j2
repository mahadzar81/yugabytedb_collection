# YugabyteDB Master configuration flags
# Generated by Ansible

--fs_data_dirs={{ yugabytedb_data_dir }}/master
--rpc_bind_addresses={{ ansible_default_ipv4.address | default(ansible_all_ipv4_addresses[0]) }}:{{ yugabytedb_master_ports }}
--server_broadcast_addresses={{ ansible_default_ipv4.address | default(ansible_all_ipv4_addresses[0]) }}:{{ yugabytedb_master_ports }}
--master_ui_bind_addresses={{ ansible_default_ipv4.address | default(ansible_all_ipv4_addresses[0]) }}:7000
--log_dir={{ yugabytedb_log_dir }}/master
--logtostderr=false
{% if yugabytedb_cloud_provider != 'onprem' %}
--cloud_provider={{ yugabytedb_cloud_provider }}
{% endif %}
--replication_factor={{ yugabytedb_replication_factor }}
{% if yugabytedb_enable_ysql %}
--enable_ysql=true
{% endif %}
