# YugabyteDB TServer configuration flags
# Generated by Ansible

--fs_data_dirs={{ yugabytedb_data_dir }}/tserver
--rpc_bind_addresses={{ ansible_default_ipv4.address | default(ansible_all_ipv4_addresses[0]) }}:{{ yugabytedb_tserver_ports }}
--server_broadcast_addresses={{ ansible_default_ipv4.address | default(ansible_all_ipv4_addresses[0]) }}:{{ yugabytedb_tserver_ports }}
--tserver_ui_bind_addresses={{ ansible_default_ipv4.address | default(ansible_all_ipv4_addresses[0]) }}:9000
--log_dir={{ yugabytedb_log_dir }}/tserver
--logtostderr=false
--cql_proxy_bind_address={{ ansible_default_ipv4.address | default(ansible_all_ipv4_addresses[0]) }}:9042
{% if yugabytedb_enable_ysql %}
--ysql_socket_dir={{ yugabytedb_data_dir }}/tserver/ysql_socket
--pgsql_proxy_bind_address={{ ansible_default_ipv4.address | default(ansible_all_ipv4_addresses[0]) }}:5433
{% endif %}
{% if yugabytedb_cloud_provider != 'onprem' %}
--cloud_provider={{ yugabytedb_cloud_provider }}
{% endif %}
--tserver_master_addrs={{ hostvars[yugabytedb_master_nodes[0]]['ansible_default_ipv4']['address'] | default(hostvars[yugabytedb_master_nodes[0]]['ansible_all_ipv4_addresses'][0]) }}:{{ yugabytedb_master_ports }}
